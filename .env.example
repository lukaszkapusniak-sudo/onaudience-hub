# onAudience Hub — environment variables template
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.
#
# Variables without a default MUST be set for that feature to work.
# Variables with a default can be left blank (the default is used).

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL — change if using a different Supabase project
SB_URL=https://nyzkkqqjnkctcmxoirdj.supabase.co

# Anon (public) key — safe to share, has no admin privileges
# Get from: Supabase Dashboard → Settings → API → Project API keys → anon public
# Used by tests and by scripts/generate-hub-config.mjs for www/hub/config.generated.js
SB_ANON_KEY=

# Optional — Google OAuth client id for Gmail in the legacy hub (defaults in generator)
# GMAIL_CLIENT_ID=

# Optional — OpenStreetMap Nominatim endpoint (defaults in generator)
# NOMINATIM_URL=

# ── Authentication (required for browser tests) ───────────────────────────────
# A valid onAudience hub user account
# Set these in GitHub Secrets as OA_EMAIL and OA_PASSWORD for CI
OA_EMAIL=
OA_PASSWORD=

# ── Lemlist (required for Lemlist tests) ──────────────────────────────────────
# API key from: https://app.lemlist.com/settings/integrations → API
# Set this in GitHub Secrets as LEMLIST_API_KEY for CI
LEMLIST_API_KEY=

# ── Anthropic (optional — required for AI/Vibe tests) ────────────────────────
# Get from: https://console.anthropic.com/settings/keys
# Set this in GitHub Secrets as ANTHROPIC_API_KEY for CI
# ANTHROPIC_API_KEY=sk-ant-...

# ── Playwright (browser E2E) ───────────────────────────────────────────────────
# Override hub base URL — must end with /hub/ for deployed layout
# PLAYWRIGHT_BASE_URL=https://lukaszkapusniak-sudo.github.io/onaudience-hub/hub/
# HUB_BASE_URL=http://localhost:5173/hub/

# ── Hub production build (optional) ───────────────────────────────────────────
# Cache-bust token for legacy hub assets in dist/hub (default: GITHUB_SHA or timestamp)
# HUB_ASSET_VERSION=

# ── GitHub (optional — only needed for deploy/push tests) ────────────────────
# Personal access token with repo scope
# GH_TOKEN=ghp_...
